# MongoDB — для локальної розробки підключай хмарний MongoDB Atlas або локальний
DATABASE_URI=mongodb+srv://user:password@cluster.mongodb.net/abect?retryWrites=true&w=majority

# Payload CMS Secret (згенеруй: openssl rand -base64 32)
PAYLOAD_SECRET=your-secret-here

# Next.js
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# Telegram Bot (для сповіщень про ліди)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_THREAD_ID=your-telegram-thread-id
